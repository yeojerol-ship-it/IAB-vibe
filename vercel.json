{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/trip-proxy/:path*",
      "destination": "/api/trip-proxy/:path*"
    },
    {
      "source": "/restapi/:path*",
      "destination": "/api/trip-proxy/restapi/:path*"
    },
    {
      "source": "/api/soa2/:path*",
      "destination": "/api/trip-proxy/restapi/soa2/:path*"
    }
  ]
}
